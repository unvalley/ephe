{
  "name": "ephe",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "pnpm run copy:wasm && vite",
    "build": "pnpm run copy:wasm && tsc && vite build",
    "preview": "vite preview",
    "lint": "pnpm lint:biome && pnpm lint:eslint",
    "lint:biome": "biome lint",
    "lint:biome:write": "biome lint --write --unsafe",
    "lint:eslint": "eslint --ext .ts,.tsx src",
    "lint:eslint:fix": "eslint --fix --ext .ts,.tsx src",
    "format": "biome format --write",
    "copy:wasm": "node --experimental-strip-types src/scripts/copy-wasm.ts",
    "test": "pnpm test:unit",
    "test:unit": "vitest src",
    "test:unit:ui": "vitest src --ui",
    "test:unit:coverage": "vitest src --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "knip": "pnpm dlx knip"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@dprint/formatter": "^0.4.1",
    "@dprint/markdown": "^0.18.0",
    "@headlessui/react": "^2.2.9",
    "@lezer/highlight": "^1.2.3",
    "@phosphor-icons/react": "^2.1.10",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "jotai": "^2.19.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "sonner": "^2.0.7",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "4.1.0",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "1.0.0",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "6.0.0-rc1",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "rollup-plugin-visualizer": "^5.14.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.5",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.2",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  }
}
